{
  "name": "mobile-landscape",
  "canvasSize": [844, 390],
  "root": {
    "type": "grid",
    "id": "root",
    "rows": ["40px", "1fr", "auto"],
    "cols": ["1fr"],
    "children": [
      {
        "type": "grid",
        "id": "player-bar",
        "description": "Obere Leiste mit Spieler-Infos und RISK-Titel",
        "row": 0,
        "col": 0,
        "rows": ["1fr"],
        "cols": ["1fr", "auto", "1fr"],
        "style": {
          "background": "linear-gradient(90deg, #3E2723, #4E342E, #3E2723)"
        },
        "children": [
          {
            "type": "grid",
            "id": "p1-chip",
            "description": "Spieler 1: Avatar, Name, Territorien und Armeen",
            "row": 0,
            "col": 0,
            "rows": ["1fr"],
            "cols": ["auto", "auto"],
            "style": {
              "background": "rgba(0,0,0,0.3)",
              "borderRadius": 6,
              "padding": "2px 6px"
            },
            "children": [
              {
                "type": "icon",
                "id": "p1-avatar",
                "description": "Avatar Spieler 1 (Kreis in Spielerfarbe)",
                "name": "person",
                "row": 0,
                "col": 0,
                "style": {
                  "fontSize": 14,
                  "color": "#E53935"
                }
              },
              {
                "type": "grid",
                "id": "p1-info",
                "description": "Name und Stats von Spieler 1",
                "row": 0,
                "col": 1,
                "rows": ["auto", "auto"],
                "cols": ["1fr"],
                "children": [
                  {
                    "type": "label",
                    "id": "p1-name",
                    "description": "Name von Spieler 1",
                    "text": "Player 1",
                    "row": 0,
                    "col": 0,
                    "style": {
                      "fontSize": 10,
                      "fontWeight": "bold",
                      "color": "#FFFFFF"
                    }
                  },
                  {
                    "type": "label",
                    "id": "p1-stats",
                    "description": "Territorien und Armeen von Spieler 1 (z.B. '🏴 5  🛡️ 12')",
                    "text": "🏴 5  🛡️ 12",
                    "row": 1,
                    "col": 0,
                    "style": {
                      "fontSize": 9,
                      "color": "rgba(255,255,255,0.7)"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "label",
            "id": "title",
            "description": "Spiel-Titel in der Mitte der oberen Leiste",
            "text": "RISK",
            "row": 0,
            "col": 1,
            "style": {
              "fontSize": 18,
              "fontWeight": "bold",
              "color": "#E57373"
            }
          },
          {
            "type": "grid",
            "id": "p2-chip",
            "description": "Spieler 2 (Bot): Avatar, Name, Territorien und Armeen",
            "row": 0,
            "col": 2,
            "rows": ["1fr"],
            "cols": ["auto", "auto"],
            "style": {
              "background": "rgba(0,0,0,0.3)",
              "borderRadius": 6,
              "padding": "2px 6px"
            },
            "children": [
              {
                "type": "grid",
                "id": "p2-info",
                "description": "Name und Stats von Spieler 2",
                "row": 0,
                "col": 0,
                "rows": ["auto", "auto"],
                "cols": ["1fr"],
                "children": [
                  {
                    "type": "label",
                    "id": "p2-name",
                    "description": "Name von Spieler 2",
                    "text": "Bot Player",
                    "row": 0,
                    "col": 0,
                    "style": {
                      "fontSize": 10,
                      "fontWeight": "bold",
                      "color": "#FFFFFF",
                      "textAlign": "right"
                    }
                  },
                  {
                    "type": "label",
                    "id": "p2-stats",
                    "description": "Territorien und Armeen von Spieler 2",
                    "text": "🏴 3  🛡️ 8",
                    "row": 1,
                    "col": 0,
                    "style": {
                      "fontSize": 9,
                      "color": "rgba(255,255,255,0.7)",
                      "textAlign": "right"
                    }
                  }
                ]
              },
              {
                "type": "icon",
                "id": "p2-avatar",
                "description": "Avatar Spieler 2 (Bot-Icon in Spielerfarbe)",
                "name": "smart_toy",
                "row": 0,
                "col": 1,
                "style": {
                  "fontSize": 14,
                  "color": "#1E88E5"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "grid",
        "id": "map-area",
        "description": "Mittlerer Bereich: Karte mit schwebenden Overlays",
        "row": 1,
        "col": 0,
        "rows": ["1fr"],
        "cols": ["1fr"],
        "children": [
          {
            "type": "list",
            "id": "attack-log",
            "description": "Schwebende Attack-Log-Box oben rechts. Zeigt die letzten Kampf-Events, klappbar.",
            "maxItems": 4,
            "row": 0,
            "col": 0,
            "style": {
              "position": "top-right",
              "background": "rgba(62,39,12,0.85)",
              "border": "rgba(255,160,0,0.4)",
              "borderRadius": 8,
              "fontSize": 9,
              "color": "rgba(255,255,255,0.7)"
            }
          }
        ]
      },
      {
        "type": "grid",
        "id": "bottom-bar",
        "description": "Unterer Bereich mit Karten-Button und Aktionsleiste",
        "row": 2,
        "col": 0,
        "rows": ["1fr"],
        "cols": ["auto", "1fr"],
        "children": [
          {
            "type": "grid",
            "id": "cards-btn",
            "description": "Karten-Button unten links. Zeigt Kartenanzahl, öffnet bei Klick die Kartenhand.",
            "row": 0,
            "col": 0,
            "rows": ["1fr"],
            "cols": ["auto", "auto"],
            "style": {
              "background": "rgba(62,39,12,0.9)",
              "border": "rgba(255,160,0,0.4)",
              "borderRadius": 8,
              "padding": "5px 8px"
            },
            "children": [
              {
                "type": "icon",
                "id": "cards-icon",
                "description": "Karten-Symbol",
                "name": "style",
                "row": 0,
                "col": 0,
                "style": {
                  "fontSize": 14,
                  "color": "#FFB300"
                }
              },
              {
                "type": "label",
                "id": "cards-count",
                "description": "Anzahl Karten auf der Hand (z.B. 'CARDS (3)')",
                "text": "CARDS (3)",
                "row": 0,
                "col": 1,
                "style": {
                  "fontSize": 10,
                  "fontWeight": "bold",
                  "color": "#FFB300"
                }
              }
            ]
          },
          {
            "type": "grid",
            "id": "action-bar",
            "description": "Phasen-abhängige Aktionsleiste. Zeigt Reinforce/Attack/Fortify-Steuerung je nach Spielphase.",
            "row": 0,
            "col": 1,
            "rows": ["auto", "auto", "auto"],
            "cols": ["1fr"],
            "style": {
              "background": "linear-gradient(180deg, rgba(62,39,12,0.95), rgba(78,52,30,0.95))",
              "border": "rgba(255,160,0,0.5)",
              "borderRadius": 10,
              "padding": "6px 10px"
            },
            "children": [
              {
                "type": "label",
                "id": "phase-label",
                "description": "Aktuelle Spielphase (REINFORCE PHASE / ATTACK PHASE / FORTIFY PHASE)",
                "text": "ATTACK PHASE",
                "row": 0,
                "col": 0,
                "style": {
                  "fontSize": 11,
                  "fontWeight": "bold",
                  "color": "#FFB300"
                }
              },
              {
                "type": "label",
                "id": "phase-subtitle",
                "description": "Kontextabhängiger Untertitel (z.B. 'Select attacker, then target')",
                "text": "Select attacker, then target",
                "row": 1,
                "col": 0,
                "style": {
                  "fontSize": 10,
                  "color": "rgba(255,255,255,0.7)"
                }
              },
              {
                "type": "grid",
                "id": "action-buttons",
                "description": "Aktions-Buttons, phasenabhängig. Attack-Phase: Würfel-Auswahl + Attack/Blitz/End Buttons",
                "row": 2,
                "col": 0,
                "rows": ["1fr"],
                "cols": ["auto", "auto", "auto", "1fr", "auto", "auto", "auto"],
                "children": [
                  {
                    "type": "button",
                    "id": "dice-1",
                    "description": "Würfel-Auswahl: 1 Würfel",
                    "text": "1",
                    "row": 0,
                    "col": 0,
                    "style": {
                      "fontSize": 12,
                      "fontWeight": "bold",
                      "background": "rgba(255,255,255,0.15)",
                      "color": "rgba(255,255,255,0.6)",
                      "borderRadius": 4,
                      "padding": "4px 6px"
                    }
                  },
                  {
                    "type": "button",
                    "id": "dice-2",
                    "description": "Würfel-Auswahl: 2 Würfel",
                    "text": "2",
                    "row": 0,
                    "col": 1,
                    "style": {
                      "fontSize": 12,
                      "fontWeight": "bold",
                      "background": "rgba(255,255,255,0.15)",
                      "color": "rgba(255,255,255,0.6)",
                      "borderRadius": 4,
                      "padding": "4px 6px"
                    }
                  },
                  {
                    "type": "button",
                    "id": "dice-3",
                    "description": "Würfel-Auswahl: 3 Würfel (Standard, selektiert)",
                    "text": "3",
                    "row": 0,
                    "col": 2,
                    "style": {
                      "fontSize": 12,
                      "fontWeight": "bold",
                      "background": "#C62828",
                      "color": "#FFFFFF",
                      "border": "#E57373",
                      "borderRadius": 4,
                      "padding": "4px 6px"
                    }
                  },
                  {
                    "type": "spacer",
                    "id": "action-spacer",
                    "row": 0,
                    "col": 3
                  },
                  {
                    "type": "button",
                    "id": "attack-btn",
                    "description": "Attack-Button: Führt einen einzelnen Angriff mit gewählter Würfelzahl aus",
                    "text": "ATTACK",
                    "row": 0,
                    "col": 4,
                    "style": {
                      "fontSize": 11,
                      "fontWeight": "bold",
                      "background": "#388E3C",
                      "color": "#FFFFFF",
                      "borderRadius": 6,
                      "padding": "7px 12px"
                    }
                  },
                  {
                    "type": "button",
                    "id": "blitz-btn",
                    "description": "Blitz-Button: Greift wiederholt an bis Sieg oder Niederlage",
                    "text": "BLITZ",
                    "row": 0,
                    "col": 5,
                    "style": {
                      "fontSize": 11,
                      "fontWeight": "bold",
                      "background": "#546E7A",
                      "color": "#FFFFFF",
                      "borderRadius": 6,
                      "padding": "7px 12px"
                    }
                  },
                  {
                    "type": "button",
                    "id": "end-btn",
                    "description": "End-Button: Beendet die aktuelle Phase (Attack→Fortify, Fortify→nächster Spieler)",
                    "text": "END",
                    "row": 0,
                    "col": 6,
                    "style": {
                      "fontSize": 11,
                      "fontWeight": "bold",
                      "background": "#B71C1C",
                      "color": "#FFFFFF",
                      "borderRadius": 6,
                      "padding": "7px 12px"
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "theme": {
    "background": "rgba(62,39,12,0.9)",
    "border": "rgba(255,193,7,0.3)",
    "text": "#FFB300",
    "borderRadius": 10
  }
}
